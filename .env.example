# Generate a secret key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Google Drive OAuth (from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Microsoft/OneDrive OAuth (from https://portal.azure.com/)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:5000/auth/microsoft/callback

# Perceptual hash similarity threshold (lower = stricter, higher = more matches)
PHASH_THRESHOLD=10
